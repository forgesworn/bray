{
  "name": "nostr-bray",
  "version": "0.0.0",
  "mcpName": "dev.forgesworn/bray",
  "description": "Trust-aware Nostr for AI and humans. Three dimensions of trust -- verification, proximity, and access -- woven into every interaction.",
  "type": "module",
  "main": "dist/exports.js",
  "types": "dist/exports.d.ts",
  "bin": {
    "nostr-bray": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/exports.js",
      "types": "./dist/exports.d.ts"
    },
    "./identity": {
      "import": "./dist/identity/index.js",
      "types": "./dist/identity/index.d.ts"
    },
    "./social": {
      "import": "./dist/social/index.js",
      "types": "./dist/social/index.d.ts"
    },
    "./trust": {
      "import": "./dist/trust/index.js",
      "types": "./dist/trust/index.d.ts"
    },
    "./relay": {
      "import": "./dist/relay/index.js",
      "types": "./dist/relay/index.d.ts"
    },
    "./zap": {
      "import": "./dist/zap/index.js",
      "types": "./dist/zap/index.d.ts"
    },
    "./safety": {
      "import": "./dist/safety/index.js",
      "types": "./dist/safety/index.d.ts"
    },
    "./event": {
      "import": "./dist/event/index.js",
      "types": "./dist/event/index.d.ts"
    },
    "./util": {
      "import": "./dist/util/index.js",
      "types": "./dist/util/index.d.ts"
    },
    "./workflow": {
      "import": "./dist/workflow/index.js",
      "types": "./dist/workflow/index.d.ts"
    },
    "./dispatch": {
      "import": "./dist/dispatch/index.js",
      "types": "./dist/dispatch/index.d.ts"
    },
    "./marketplace": {
      "import": "./dist/marketplace/index.js",
      "types": "./dist/marketplace/index.d.ts"
    },
    "./privacy": {
      "import": "./dist/privacy/index.js",
      "types": "./dist/privacy/index.d.ts"
    },
    "./moderation": {
      "import": "./dist/moderation/index.js",
      "types": "./dist/moderation/index.d.ts"
    },
    "./signet": {
      "import": "./dist/signet/index.js",
      "types": "./dist/signet/index.d.ts"
    },
    "./vault": {
      "import": "./dist/vault/index.js",
      "types": "./dist/vault/index.d.ts"
    },
    "./handler": {
      "import": "./dist/handler/index.js",
      "types": "./dist/handler/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    },
    "./types": {
      "import": "./dist/types-public.js",
      "types": "./dist/types-public.d.ts"
    }
  },
  "files": [
    "dist",
    "dist/widgets",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-widgets.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "nostr",
    "mcp",
    "trust",
    "web-of-trust",
    "identity",
    "verification",
    "signet",
    "dominion",
    "encrypted",
    "access-control",
    "privacy",
    "lightning",
    "nip-46",
    "nsec-tree",
    "ring-signatures",
    "attestations"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/forgesworn/bray.git"
  },
  "homepage": "https://github.com/forgesworn/bray#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@forgesworn/range-proof": "^2.0.1",
    "@forgesworn/ring-sig": "^3.0.0",
    "@forgesworn/shamir-words": "^1.0.4",
    "@modelcontextprotocol/ext-apps": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "canary-kit": "^2.6.2",
    "dominion-protocol": "^1.0.0",
    "nostr-attestations": "^2.5.4",
    "nostr-tools": "^2.23.3",
    "nostr-veil": "^0.8.4",
    "nsec-tree": "^1.4.2",
    "signet-protocol": "^1.1.0",
    "socks-proxy-agent": "^10.0.0",
    "spoken-token": "^2.0.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
