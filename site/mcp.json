{
  "name": "nostr-bray",
  "display_name": "nostr-bray",
  "description": "Trust-aware Nostr MCP server for AI agents and humans. 238 tools across 27 groups: identity, social, DMs, trust attestations, encrypted dispatch, Lightning payments, privacy proofs, blossom media, handler discovery, compound workflows, and more. Three dimensions of trust -- verification (Signet), proximity (web-of-trust), and access (Dominion) -- woven into every interaction.",
  "short_description": "Trust-aware Nostr MCP. 238 tools for sovereign identity, trust scoring, AI-to-AI dispatch, and Lightning payments.",
  "homepage": "https://bray.forgesworn.dev",
  "repository": "https://github.com/forgesworn/bray",
  "npm": "https://www.npmjs.com/package/nostr-bray",
  "package_name": "nostr-bray",
  "command": "npx nostr-bray",
  "licence": "MIT",
  "version": "1.31.0",
  "transport": ["stdio", "http"],
  "categories": ["communication", "identity", "social", "payments", "privacy"],
  "tags": [
    "nostr",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "identity",
    "trust",
    "web-of-trust",
    "lightning",
    "nwc",
    "nostr-wallet-connect",
    "nip-46",
    "encrypted",
    "ring-signature",
    "zero-knowledge",
    "dispatch",
    "attestations",
    "sovereign",
    "privacy",
    "typescript"
  ],
  "capabilities": {
    "tools": 235,
    "tool_groups": [
      "identity",
      "social",
      "dm",
      "articles",
      "search",
      "calendar",
      "wiki",
      "badges",
      "communities",
      "trust",
      "moderation",
      "dispatch",
      "relay",
      "zap",
      "safety",
      "signet",
      "vault",
      "marketplace",
      "privacy",
      "blossom",
      "groups",
      "scheduled",
      "community-nips",
      "utility",
      "workflow",
      "handler",
      "meta"
    ],
    "auth_methods": ["bunker_nip46", "ncryptsec_nip49", "key_file", "env_var"],
    "supported_nips": [
      "NIP-01", "NIP-02", "NIP-05", "NIP-09", "NIP-11", "NIP-17", "NIP-19",
      "NIP-23", "NIP-29", "NIP-32", "NIP-40", "NIP-42", "NIP-44", "NIP-45",
      "NIP-46", "NIP-49", "NIP-50", "NIP-51", "NIP-52", "NIP-54", "NIP-57",
      "NIP-58", "NIP-65", "NIP-72", "NIP-78", "NIP-85", "NIP-89",
      "NIP-99", "NIP-A7", "NIP-VA"
    ]
  },
  "quick_start": {
    "config": {
      "mcpServers": {
        "nostr": {
          "command": "npx",
          "args": ["nostr-bray"],
          "env": {
            "BUNKER_URI": "bunker://...",
            "NOSTR_RELAYS": "wss://relay.damus.io,wss://nos.lol"
          }
        }
      }
    },
    "verify": "Ask your AI to call whoami"
  },
  "llms_txt": "https://raw.githubusercontent.com/forgesworn/bray/main/llms.txt",
  "llms_full_txt": "https://raw.githubusercontent.com/forgesworn/bray/main/llms-full.txt"
}
